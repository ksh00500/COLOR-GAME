{
  "name": "@color-game/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "db:check": "tsx src/db/check.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "admin:bootstrap": "tsx src/db/bootstrap-admin.ts",
    "ai:export-training": "tsx src/db/export-ai-training.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@color-game/ai-engine": "workspace:*",
    "@color-game/game-core": "workspace:*",
    "@color-game/shared-types": "workspace:*",
    "@fastify/cors": "11.2.0",
    "fastify": "5.6.2",
    "google-auth-library": "10.3.0",
    "pg": "8.21.0",
    "socket.io": "4.8.1",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/node": "22.19.3",
    "@types/pg": "8.20.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "vitest": "3.0.7"
  }
}
